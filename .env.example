# Copy ke .env di root repo (jangan commit .env)
# cp .env.example .env

APPLE_ID=email@example.com
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 1 = izinkan reinstall WDA otomatis saat cert expired (butuh kode 2FA di terminal)
# 0 = disarankan setelah WDA sudah terpasang — reinstall manual: install_wda_altserver.sh
IOS_AUTOMATOR_INSTALL_WDA=0
# IOS_ALLOW_WDA_REINSTALL=1

# -----------------------------------------------------------------------------
# stack (umum — IG / X / Facebook)
# -----------------------------------------------------------------------------
IOS_KEEP_SCREEN_ON=1
# IOS_KEEP_AWAKE_SEC=86400
IOS_ENSURE_DEVELOPER_MODE=1
# IOS_SKIP_DEVMODE_CLI_ENABLE=1
# Cleanup: wda | all | none
IOS_CLEANUP_ON_EXIT=wda
# 0 = skip probe cert (~20s). 1 = test launch sebelum stack.
IOS_CHECK_WDA_CERT=0
IOS_WDA_BOOT_WAIT_SEC=12
IOS_WDA_HTTP_WAIT_SEC=30
# IOS_MOUNT_DEV_IMAGE=0
# ALTSERVER_ANISETTE_SERVER=https://ani.sidestore.io
# WDA_DIR=/home/lattepanda/wda
# ALTSERVER_BIN=/home/lattepanda/wda/AltServer

# -----------------------------------------------------------------------------
# instagram  (run_ig_profile.sh)
# -----------------------------------------------------------------------------
# Archive Stories: max screenshot (1–100). YEAR diisi → max PER TAHUN.
IOS_ARCHIVE_MAX_SCREENSHOTS=5
IOS_ARCHIVE_SCROLL_PAUSE_SEC=1.0
# up = jari ke bawah (default). down = jari ke atas.
IOS_ARCHIVE_SCROLL_DIRECTION=up
# Filter tahun inklusif. Kosongkan = tanpa filter.
# IOS_ARCHIVE_YEAR_FROM=2023
# IOS_ARCHIVE_YEAR_TO=2025
# IOS_ARCHIVE_BANNER_MAX_SCROLLS=12

# -----------------------------------------------------------------------------
# x  (run_x_profile.sh)
# -----------------------------------------------------------------------------
IOS_X_MAX_SCREENSHOTS=5
IOS_X_SCROLL_PAUSE_SEC=0.20
IOS_X_SCROLL_DURATION_SEC=0.15
# Fraksi tinggi layar (otomatis menyesuaikan ukuran HP)
IOS_X_SCROLL_DISTANCE=0.78
IOS_X_FIRST_SCROLL_DISTANCE=0.90
# down = jari ke atas (default). up = jari ke bawah.
IOS_X_SCROLL_DIRECTION=down
# 1 = simpan page_source_home/drawer (debug — lambat karena dump tree besar)
# IOS_X_DEBUG_SOURCE=0

# -----------------------------------------------------------------------------
# facebook  (run_fb_profile.sh)
# -----------------------------------------------------------------------------
# Belum ada knob khusus — Home → Profile saja.
# Cadangan (aktifkan nanti kalau perlu scroll posts FB):
# IOS_FB_MAX_SCREENSHOTS=5
# IOS_FB_SCROLL_PAUSE_SEC=0.35
# IOS_FB_SCROLL_DISTANCE=0.78
# IOS_FB_SCROLL_DIRECTION=down
