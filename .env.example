# Copy ke .env di root repo (jangan commit .env)
# cp .env.example .env

APPLE_ID=email@example.com
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 1 = izinkan reinstall WDA otomatis saat cert expired (butuh kode 2FA di terminal)
# 0 = disarankan setelah WDA sudah terpasang — reinstall manual: install_wda_altserver.sh
IOS_AUTOMATOR_INSTALL_WDA=0
# IOS_ALLOW_WDA_REINSTALL=1   # sama seperti IOS_AUTOMATOR_INSTALL_WDA=1 untuk cert expired

# Layar iPhone tetap nyala saat automation remote (default: 1)
IOS_KEEP_SCREEN_ON=1
# IOS_KEEP_AWAKE_SEC=86400

# Auto-enable Developer Mode via go-ios AMFI (bukan ideviceinfo — itu read-only)
IOS_ENSURE_DEVELOPER_MODE=1
# HP pakai passcode → set 1 supaya tidak loop reveal/enable CLI (manual di Settings saja)
# IOS_SKIP_DEVMODE_CLI_ENABLE=1

# Cleanup setelah run_ig_archive.sh selesai:
#   wda  = stop WDA + keep-screen-on, tunnel tetap (disarankan server)
#   all  = stop semua termasuk tunnel
#   none = biarkan semua hidup (debug / run beruntun cepat)
IOS_CLEANUP_ON_EXIT=wda

# Opsional
# ALTSERVER_ANISETTE_SERVER=https://ani.sidestore.io
# WDA_DIR=/home/lattepanda/wda
# ALTSERVER_BIN=/home/lattepanda/wda/AltServer
